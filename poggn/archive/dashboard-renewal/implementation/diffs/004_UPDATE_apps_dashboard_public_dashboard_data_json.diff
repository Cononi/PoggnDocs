+                    "content": "diff --git a/packages/cli/package.json b/packages/cli/package.json\nnew file mode 100644\nindex 0000000..c8dbe5c\n--- /dev/null\n+++ b/packages/cli/package.json\n@@ -0,0 +1,39 @@\n+{\n+  \"name\": \"@pgg/cli\",\n+  \"version\": \"0.1.0\",\n+  \"description\": \"CLI for initializing and operating the pgg workflow workspace\",\n+  \"type\": \"module\",\n+  \"bin\": {\n+    \"pgg\": \"dist/index.js\"\n+  },\n+  \"files\": [\n+    \"dist\",\n+    \"README.md\"\n+  ],\n+  \"license\": \"MIT\",\n+  \"repository\": {\n+    \"type\": \"git\",\n+    \"url\": \"https://github.com/Cononi/ygg.git\",\n+    \"directory\": \"packages/cli\"\n+  },\n+  \"homepage\": \"https://github.com/Cononi/ygg/tree/main/packages/cli\",\n+  \"bugs\": {\n+    \"url\": \"https://github.com/Cononi/ygg/issues\"\n+  },\n+  \"keywords\": [\n+    \"pgg\",\n+    \"codex\",\n+    \"workflow\",\n+    \"cli\",\n+    \"pnpm\"\n+  ],\n+  \"publishConfig\": {\n+    \"access\": \"public\"\n+  },\n+  \"scripts\": {\n+    \"build\": \"tsc -p tsconfig.json\"\n+  },\n+  \"dependencies\": {\n+    \"@pgg/core\": \"workspace:*\"\n+  }\n+}\n",
